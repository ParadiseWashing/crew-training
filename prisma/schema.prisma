generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth v5) ────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core App Models ──────────────────────────────────────────────────────────

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  inviteToken   String?        @unique
  inviteStatus  InviteStatus   @default(ACCEPTED)
  inviteExpires DateTime?
  systemRole    SystemRole     @default(TRAINEE)
  jobRoleId     String?
  jobRole       JobRole?       @relation("UserPrimaryJobRole", fields: [jobRoleId], references: [id])
  jobRoles      UserJobRole[]
  accounts      Account[]
  sessions      Session[]
  assignments   Assignment[]
  quizAttempts  QuizAttempt[]
  signOffs      SignOff[]
  stepProgress  StepProgress[]
  auditFlags    TrainingAuditFlag[]
  startedInterviews WorkingInterview[]    @relation("StartedInterviews")
  evaluatedDays     WorkingInterviewDay[] @relation("EvaluatedDays")
  weeklySignOffsAsTrainee WeeklySignOff[] @relation("WeeklySignOffTrainee")
  weeklySignOffsAsTrainer WeeklySignOff[] @relation("WeeklySignOffTrainer")
  handbookSignatures      HandbookSignature[] @relation("UserHandbookSignatures")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

enum SystemRole {
  ADMIN
  TRAINEE
}

enum InviteStatus {
  PENDING
  ACCEPTED
}

model JobRole {
  id                    String           @id @default(cuid())
  title                 String
  description           String?
  color                 String?          @default("#3B82F6")
  canAccessLeadership   Boolean          @default(false)
  canSignOffTraining    Boolean          @default(false)
  users                 User[]           @relation("UserPrimaryJobRole")
  userAssignments       UserJobRole[]
  subjects              JobRoleSubject[]
  createdAt             DateTime         @default(now())
}

model UserJobRole {
  userId     String
  jobRoleId  String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobRole    JobRole  @relation(fields: [jobRoleId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([userId, jobRoleId])
  @@index([jobRoleId])
}

model Subject {
  id              String           @id @default(cuid())
  title           String
  description     String?
  coverImage      String?
  category        SubjectCategory  @default(PROCESSES)
  isPublished     Boolean          @default(false)
  requiresSignOff Boolean          @default(false)
  orderIndex      Int              @default(0)
  topics          Topic[]
  jobRoles        JobRoleSubject[]
  assignments     Assignment[]
  signOffs        SignOff[]
  weeklySignOffs  WeeklySignOff[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

enum SubjectCategory {
  COMPANY
  POLICIES
  PROCESSES
  LEADERSHIP
}

model JobRoleSubject {
  jobRoleId String
  subjectId String
  jobRole   JobRole @relation(fields: [jobRoleId], references: [id], onDelete: Cascade)
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([jobRoleId, subjectId])
}

model Topic {
  id          String   @id @default(cuid())
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  orderIndex  Int
  weekNumber  Int?
  dayNumber   Int?
  steps       Step[]
  quiz        Quiz?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Step {
  id         String         @id @default(cuid())
  topicId    String
  topic      Topic          @relation(fields: [topicId], references: [id], onDelete: Cascade)
  title      String
  stepType   StepType       @default(CONTENT)
  content    Json
  orderIndex Int
  progress   StepProgress[]
  handbookSignatures HandbookSignature[] @relation("StepHandbookSignatures")
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

enum StepType {
  CONTENT
  PDF
  SIGNATURE
}

model StepProgress {
  id               String   @id @default(cuid())
  userId           String
  stepId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  step             Step     @relation(fields: [stepId], references: [id], onDelete: Cascade)
  completedAt      DateTime @default(now())
  timeSpentSeconds Int      @default(0)
  scrolledToBottom Boolean  @default(false)

  @@unique([userId, stepId])
}

model Quiz {
  id           String        @id @default(cuid())
  topicId      String        @unique
  topic        Topic         @relation(fields: [topicId], references: [id], onDelete: Cascade)
  passingScore Int           @default(100)
  maxAttempts  Int           @default(3)
  questions    Question[]
  attempts     QuizAttempt[]
}

model Question {
  id            String       @id @default(cuid())
  quizId        String
  quiz          Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  text          String
  type          QuestionType
  options       Json?
  correctAnswer Json?
  orderIndex    Int
}

enum QuestionType {
  MULTIPLE_CHOICE
  MULTIPLE_SELECT
  TRUE_FALSE
  WRITTEN_RESPONSE
}

model Assignment {
  id                 String           @id @default(cuid())
  userId             String
  subjectId          String
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject            Subject          @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  status             AssignmentStatus @default(NOT_STARTED)
  progressPercentage Float            @default(0)
  dueDate            DateTime?
  assignedAt         DateTime         @default(now())
  completedAt        DateTime?

  @@unique([userId, subjectId])
}

enum AssignmentStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model QuizAttempt {
  id               String   @id @default(cuid())
  userId           String
  quizId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz             Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  score            Float
  passed           Boolean
  answers          Json
  attemptNum       Int
  timeTakenSeconds Int      @default(0)
  takenAt          DateTime @default(now())
}

enum AuditFlagType {
  SPEED_READ
  QUIZ_PATTERN
  QUIZ_SPEED
  RAPID_MODULE
}

model TrainingAuditFlag {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  flagType    AuditFlagType
  subjectId   String?
  topicId     String?
  stepId      String?
  quizId      String?
  details     Json?
  dismissed   Boolean       @default(false)
  dismissedBy String?
  dismissedAt DateTime?
  createdAt   DateTime      @default(now())
}

model SignOff {
  id         String   @id @default(cuid())
  userId     String
  subjectId  String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  signedName String
  signedAt   DateTime @default(now())
}

// ─── Working Interviews (Leadership) ──────────────────────────────────────────

model WorkingInterview {
  id            String                  @id @default(cuid())
  candidateName String
  status        WorkingInterviewStatus  @default(IN_PROGRESS)
  startedById   String
  startedBy     User                    @relation("StartedInterviews", fields: [startedById], references: [id])
  startedAt     DateTime                @default(now())
  completedAt   DateTime?
  days          WorkingInterviewDay[]
}

enum WorkingInterviewStatus {
  IN_PROGRESS
  PASSED
  DISQUALIFIED
}

model WorkingInterviewDay {
  id            String                @id @default(cuid())
  interviewId   String
  interview     WorkingInterview      @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  day           Int                   // 1, 2, or 3
  evaluatorId   String
  evaluator     User                  @relation("EvaluatedDays", fields: [evaluatorId], references: [id])
  ratings       Json                  // { taskRatings: {...}, observations: {...}, dayThreeFields: {...} }
  autoDqFlags   Json                  // string[] of triggered flag codes
  notes         String?
  decision      WorkingInterviewDecision
  submittedAt   DateTime              @default(now())

  @@unique([interviewId, day])
}

enum WorkingInterviewDecision {
  CONTINUE
  DQ
  HIRE
  DO_NOT_HIRE
}

// ─── Weekly Sign-Off ──────────────────────────────────────────────────────────
// Trainer-only weekly certification. The trainer evaluates a trainee at the end
// of each week of a multi-week onboarding curriculum (e.g. Final Cleaning -
// Custom Homes Week 1-4) and records pass/fail with per-topic ratings.

model WeeklySignOff {
  id                String           @id @default(cuid())
  subjectId         String
  subject           Subject          @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  weekNumber        Int
  traineeUserId     String
  trainee           User             @relation("WeeklySignOffTrainee", fields: [traineeUserId], references: [id], onDelete: Cascade)
  trainerUserId     String
  trainer           User             @relation("WeeklySignOffTrainer", fields: [trainerUserId], references: [id])
  decision          WeeklySignOffDecision
  topicRatings      Json             // { [topicId]: "PASS" | "NEEDS_WORK" }
  notes             String?
  trainerSignedName String
  signedAt          DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([subjectId, weekNumber, traineeUserId])
  @@index([trainerUserId])
}

enum WeeklySignOffDecision {
  PASSED
  FAILED
}

// ─── Handbook Signature ──────────────────────────────────────────────────────
// Audit record for each time a trainee signs an employee-handbook style
// document. The signed PDF lives in Google Drive; this row stores metadata
// + a permanent UploadThing backup so we never lose the audit trail.

model HandbookSignature {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation("UserHandbookSignatures", fields: [userId], references: [id], onDelete: Cascade)
  stepId            String
  step              Step     @relation("StepHandbookSignatures", fields: [stepId], references: [id], onDelete: Cascade)
  // The exact name printed (snapshot of the user's name at signing time).
  printedName       String
  signedAt          DateTime @default(now())
  signatureMethod   SignatureMethod
  // Typed-font name used when signatureMethod=TYPED. Empty otherwise.
  typedSignatureText String?
  // Drive
  driveFileId       String?
  driveFileName     String?
  // Audit
  ipAddress         String?
  userAgent         String?
  pdfSourceUrl      String?
  // Backup copy on UploadThing in case the Drive file is deleted/moved
  signedPdfUrl      String?

  @@index([userId])
  @@index([stepId])
}

enum SignatureMethod {
  DRAWN
  TYPED
}
